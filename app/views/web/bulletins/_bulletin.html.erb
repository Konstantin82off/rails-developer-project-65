<div class="col-md-6 mb-4">
  <div class="card h-100">
    <% if bulletin.image.attached? %>
      <%= image_tag bulletin.image.variant(resize_to_limit: [300, 200]), class: "card-img-top" %>
    <% end %>
    <div class="card-body">
      <h5 class="card-title"><%= link_to bulletin.title, bulletin_path(bulletin) %></h5>
      <p class="card-text"><%= truncate(bulletin.description, length: 100) %></p>
      <p class="card-text">
        <small class="text-muted">
          Категория: <%= bulletin.category.name %><br>
          Автор: <%= bulletin.user.name %><br>
          <%= time_ago_in_words(bulletin.created_at) %> назад
        </small>
      </p>
    </div>
  </div>
</div>
