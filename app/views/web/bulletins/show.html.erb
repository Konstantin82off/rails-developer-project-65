<div class="container mt-4">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h2 class="mb-0"><%= @bulletin.title %></h2>
          <span class="badge bg-primary"><%= @bulletin.category.name %></span>
        </div>

        <div class="card-body">
          <% if @bulletin.image.attached? %>
            <div class="text-center mb-4">
              <%= image_tag @bulletin.image.variant(resize_to_limit: [600, 400]), class: "img-fluid rounded" %>
            </div>
          <% end %>

          <div class="mb-4">
            <h5><%= t('web.bulletins.show.description') %>:</h5>
            <p class="lead"><%= @bulletin.description %></p>
          </div>

          <div class="row mb-3">
            <div class="col-sm-6">
              <strong><%= t('web.bulletins.show.author') %>:</strong> <%= @bulletin.user.name %>
            </div>
            <div class="col-sm-6">
              <strong><%= t('web.bulletins.show.created_at') %>:</strong> <%= l(@bulletin.created_at, format: :long) %>
            </div>
          </div>
        </div>

        <div class="card-footer">
          <div class="d-flex justify-content-between align-items-center">
            <%= link_to t('web.bulletins.show.back'), bulletins_path, class: 'btn btn-outline-secondary' %>

            <div class="d-flex gap-2">
              <% if signed_in? && current_user == @bulletin.user %>
                <% if @bulletin.draft? %>
                  <%= button_to t('web.bulletins.show.to_moderate'), to_moderate_bulletin_path(@bulletin), method: :patch, class: 'btn btn-outline-primary' %>
                <% end %>

                <%= link_to t('common.edit'), edit_bulletin_path(@bulletin), class: 'btn btn-outline-primary' %>

                <% if @bulletin.may_archive? %>
                  <%= button_to t('web.bulletins.show.archive'), archive_bulletin_path(@bulletin), method: :patch, class: 'btn btn-outline-warning', data: { confirm: t('common.confirm') } %>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
