<%= form_with model: @bulletin, local: true, class: 'mt-4' do |f| %>
  <% if @bulletin.errors.any? %>
    <div class="alert alert-danger">
      <h5><%= t('errors.messages.prohibited', count: @bulletin.errors.count, model: t('activerecord.models.bulletin')) %></h5>
      <ul>
        <% @bulletin.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, class: 'form-label' do %>
      <%= t('activerecord.attributes.bulletin.title') %>
      <span class="text-muted cursor-help"
            data-bs-toggle="tooltip"
            data-bs-placement="right"
            title="<%= t('activerecord.errors.models.bulletin.attributes.title.blank') %>">*</span>
    <% end %>
    <%= f.text_field :title, class: class_names('form-control', 'is-invalid': @bulletin.errors[:title].any?), required: true %>
    <% if @bulletin.errors[:title].any? %>
      <div class="invalid-feedback">
        <%= @bulletin.errors[:title].join(', ') %>
      </div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: 'form-label' do %>
      <%= t('activerecord.attributes.bulletin.description') %>
      <span class="text-muted cursor-help"
            data-bs-toggle="tooltip"
            data-bs-placement="right"
            title="<%= t('activerecord.errors.models.bulletin.attributes.description.blank') %>">*</span>
    <% end %>
    <%= f.text_area :description, class: class_names('form-control', 'is-invalid': @bulletin.errors[:description].any?), rows: 5, required: true %>
    <% if @bulletin.errors[:description].any? %>
      <div class="invalid-feedback">
        <%= @bulletin.errors[:description].join(', ') %>
      </div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :category_id, t('activerecord.attributes.bulletin.category'), class: 'form-label' %>
    <%= f.collection_select :category_id, Category.all, :id, :name,
        { prompt: t('web.bulletins.new.select_category') },
        class: class_names('form-select', 'is-invalid': @bulletin.errors[:category_id].any?) %>
    <% if @bulletin.errors[:category_id].any? %>
      <div class="invalid-feedback">
        <%= t('activerecord.errors.models.bulletin.attributes.category.required') %>
      </div>
    <% end %>
  </div>

  <div class="mb-3">
    <%= f.label :image, class: 'form-label' do %>
      <%= t('activerecord.attributes.bulletin.image') %>
      <span class="text-muted cursor-help"
            data-bs-toggle="tooltip"
            data-bs-placement="right"
            title="<%= t('activerecord.errors.models.bulletin.attributes.image.blank') %>">*</span>
    <% end %>
    <%= f.file_field :image, class: class_names('form-control', 'is-invalid': @bulletin.errors[:image].any?), accept: 'image/*' %>
    <% if @bulletin.errors[:image].any? %>
      <div class="invalid-feedback d-block">
        <%= t('activerecord.errors.models.bulletin.attributes.image.blank') %>
      </div>
    <% end %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit yield(:submit_text), class: 'btn btn-primary' %>
    <%= link_to t('web.bulletins.new.cancel'), root_path, class: 'btn btn-secondary' %>
  </div>
<% end %>
