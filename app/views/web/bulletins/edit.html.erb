<div class="container mt-4">
  <div class="border rounded shadow p-4 mb-4 bg-white">
    <h1 class="h3 mb-2 pb-2 border-bottom"><%= t('web.bulletins.edit.title') %></h1>

    <%= form_with model: @bulletin, local: true, class: 'mt-4' do |f| %>
      <% if @bulletin.errors.any? %>
        <div class="alert alert-danger">
          <h5><%= t('errors.messages.prohibited', count: @bulletin.errors.count, model: t('activerecord.models.bulletin')) %></h5>
          <ul>
            <% @bulletin.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :title, class: 'form-label' do %>
          <%= t('activerecord.attributes.bulletin.title') %>
          <span class="text-muted" data-bs-toggle="tooltip" data-bs-placement="right" title="<%= t('activerecord.errors.models.bulletin.attributes.title.blank') %>" style="cursor: help;">*</span>
        <% end %>
        <%= f.text_field :title, class: "form-control #{'is-invalid' if @bulletin.errors[:title].any?}", required: true %>
        <% if @bulletin.errors[:title].any? %>
          <div class="invalid-feedback">
            <%= @bulletin.errors[:title].join(', ') %>
          </div>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.label :description, class: 'form-label' do %>
          <%= t('activerecord.attributes.bulletin.description') %>
          <span class="text-muted" data-bs-toggle="tooltip" data-bs-placement="right" title="<%= t('activerecord.errors.models.bulletin.attributes.description.blank') %>" style="cursor: help;">*</span>
        <% end %>
        <%= f.text_area :description, class: "form-control #{'is-invalid' if @bulletin.errors[:description].any?}", rows: 5, required: true %>
        <% if @bulletin.errors[:description].any? %>
          <div class="invalid-feedback">
            <%= @bulletin.errors[:description].join(', ') %>
          </div>
        <% end %>
      </div>

      <div class="mb-3">
        <%= f.label :category_id, t('activerecord.attributes.bulletin.category'), class: 'form-label' %>
        <%= f.collection_select :category_id, Category.all, :id, :name,
            { prompt: t('web.bulletins.new.select_category') },
            class: "form-select #{'is-invalid' if @bulletin.errors[:category_id].any?}" %>
        <% if @bulletin.errors[:category_id].any? %>
          <div class="invalid-feedback">
            <%= t('activerecord.errors.models.bulletin.attributes.category.required') %>
          </div>
        <% end %>
      </div>

      <% if @bulletin.image.attached? %>
        <div class="mb-3">
          <p><%= t('web.bulletins.edit.current_image') %>:</p>
          <%= image_tag @bulletin.image.variant(resize_to_limit: [200, 200]), class: 'img-thumbnail' %>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :image, class: 'form-label' do %>
          <%= t('activerecord.attributes.bulletin.image') %>
          <span class="text-muted" data-bs-toggle="tooltip" data-bs-placement="right" title="<%= t('activerecord.errors.models.bulletin.attributes.image.blank') %>" style="cursor: help;">?</span>
        <% end %>
        <%= f.file_field :image, class: "form-control #{'is-invalid' if @bulletin.errors[:image].any?}", accept: 'image/*' %>
        <% if @bulletin.errors[:image].any? %>
          <div class="invalid-feedback d-block">
            <%= t('activerecord.errors.models.bulletin.attributes.image.blank') %>
          </div>
        <% end %>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit t('web.bulletins.edit.submit'), class: 'btn btn-primary' %>
        <%= link_to t('web.bulletins.edit.cancel'), @bulletin, class: 'btn btn-secondary' %>
      </div>
    <% end %>
  </div>
</div>
