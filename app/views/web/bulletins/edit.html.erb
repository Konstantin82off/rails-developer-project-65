<div class="container mt-4">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <h1><%= t('web.bulletins.edit.title') %></h1>

      <%= form_with model: @bulletin, local: true, class: 'mt-4' do |f| %>
        <% if @bulletin.errors.any? %>
          <div class="alert alert-danger">
            <h5><%= pluralize(@bulletin.errors.count, 'error') %> prohibited this bulletin from being saved:</h5>
            <ul>
              <% @bulletin.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :title, t('web.bulletins.edit.title_field'), class: 'form-label' %>
          <%= f.text_field :title, class: 'form-control', required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :description, t('web.bulletins.edit.description'), class: 'form-label' %>
          <%= f.text_area :description, class: 'form-control', rows: 5, required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :category_id, t('web.bulletins.edit.category'), class: 'form-label' %>
          <%= f.collection_select :category_id, Category.all, :id, :name, {}, class: 'form-select' %>
        </div>

        <% if @bulletin.image.attached? %>
          <div class="mb-3">
            <p><%= t('web.bulletins.edit.current_image') %>:</p>
            <%= image_tag @bulletin.image.variant(resize_to_limit: [200, 200]), class: 'img-thumbnail' %>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :image, t('web.bulletins.edit.image'), class: 'form-label' %>
          <%= f.file_field :image, class: 'form-control', accept: 'image/*' %>
          <div class="form-text"><%= t('web.bulletins.edit.image_hint') %></div>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit t('web.bulletins.edit.submit'), class: 'btn btn-primary' %>
          <%= link_to t('web.bulletins.edit.cancel'), @bulletin, class: 'btn btn-secondary' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
