<div class="container px-4 mt-4"> <!-- Добавляем px-4 для отступов по бокам -->
  <nav class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= t('web.bulletins.index.title') %></h1>
    <% if signed_in? %>
      <%= link_to t('web.bulletins.index.new_bulletin'), new_bulletin_path, class: 'btn btn-primary' %>
    <% end %>
  </nav>

  <!-- Блок с поиском и фильтрацией + карточки (единая рамка) -->
  <div class="border rounded p-4"> <!-- Рамка, скругление, внутренние отступы -->

    <!-- Форма поиска -->
    <%= search_form_for @q, class: 'd-flex align-items-center gap-3 mb-4', method: :get do |f| %>
      <div class="col-md-5 flex-grow-1">
        <%= f.search_field :title_or_description_cont,
            class: 'form-control',
            placeholder: t('web.bulletins.index.search_placeholder') %>
      </div>
      <div class="col-md-4">
        <%= f.collection_select :category_id_eq,
            Category.all,
            :id,
            :name,
            { include_blank: t('web.bulletins.index.all_categories') },
            class: 'form-select' %>
      </div>
      <button
        type="submit"
        class="btn btn-primary btn-sm"
        data-bs-tooltip="true"
        title="<%= t('web.bulletins.index.search') %>"
      >
        <%= t('web.bulletins.index.search') %>
      </button>
      <%= link_to t('web.bulletins.index.reset'), root_path,
          class: 'btn btn-outline-secondary btn-sm' %>
    <% end %>

    <% if @bulletins.any? %>
      <div class="row g-2 d-flex flex-wrap">
        <% @bulletins.each do |bulletin| %>
          <%= render bulletin %>
        <% end %>
      </div>
      <!-- Пагинация -->
      <div class="mt-4">
        <%= paginate @bulletins, theme: 'bootstrap4' %>
      </div>
    <% else %>
      <div class="alert alert-info">
        <%= t('web.bulletins.index.no_bulletins') %>
      </div>
    <% end %>
  </div> <!-- Конец блока с рамкой (поиск + карточки) -->
</div>
