<div class="container mt-4">
  <div class="border rounded shadow p-4 mb-4 bg-white">
    <h1 class="h3 mb-2 pb-2 border-bottom"><%= t('web.bulletins.new.title') %></h1>

    <%= form_with model: @bulletin, local: true, class: 'mt-4' do |f| %>
      <% if @bulletin.errors.any? %>
        <div class="alert alert-danger">
          <h5><%= t('errors.messages.prohibited', count: @bulletin.errors.count) %></h5>
          <ul>
            <% @bulletin.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :title, class: 'form-label' do %>
          <%= t('web.bulletins.new.title_field') %>
          <span class="text-muted" data-bs-toggle="tooltip" data-bs-placement="right" title="<%= t('web.bulletins.new.title_required') %>" style="cursor: help;">*</span>
        <% end %>
        <%= f.text_field :title, class: 'form-control', required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :description, class: 'form-label' do %>
          <%= t('web.bulletins.new.description') %>
          <span class="text-muted" data-bs-toggle="tooltip" data-bs-placement="right" title="<%= t('web.bulletins.new.description_required') %>" style="cursor: help;">*</span>
        <% end %>
        <%= f.text_area :description, class: 'form-control', rows: 5, required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :category_id, t('web.bulletins.new.category'), class: 'form-label' %>
        <%= f.collection_select :category_id, Category.all, :id, :name, { prompt: t('web.bulletins.new.select_category') }, class: 'form-select' %>
      </div>

      <div class="mb-3">
        <%= f.label :image, class: 'form-label' do %>
          <%= t('web.bulletins.new.image') %>
          <span class="text-muted" data-bs-toggle="tooltip" data-bs-placement="right" title="<%= t('web.bulletins.new.image_hint') %>" style="cursor: help;">*</span>
        <% end %>
        <%= f.file_field :image, class: 'form-control', accept: 'image/*' %>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit t('web.bulletins.new.submit'), class: 'btn btn-primary' %>
        <%= link_to t('web.bulletins.new.cancel'), root_path, class: 'btn btn-secondary' %>
      </div>
    <% end %>
  </div>
</div>
