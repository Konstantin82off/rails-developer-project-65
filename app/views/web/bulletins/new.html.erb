<div class="container mt-4">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <h1><%= t('web.bulletins.new.title') %></h1>

      <%= form_with model: @bulletin, local: true, class: 'mt-4' do |f| %>
        <% if @bulletin.errors.any? %>
          <div class="alert alert-danger">
            <h5><%= t('errors.messages.prohibited', count: @bulletin.errors.count) %></h5>
            <ul>
              <% @bulletin.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :title, t('web.bulletins.new.title_field'), class: 'form-label' %>
          <%= f.text_field :title, class: 'form-control', required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :description, t('web.bulletins.new.description'), class: 'form-label' %>
          <%= f.text_area :description, class: 'form-control', rows: 5, required: true %>
        </div>

        <div class="mb-3">
          <%= f.label :category_id, t('web.bulletins.new.category'), class: 'form-label' %>
          <%= f.collection_select :category_id, Category.all, :id, :name, { prompt: t('web.bulletins.new.select_category') }, class: 'form-select' %>
        </div>

        <div class="mb-3">
          <%= f.label :image, t('web.bulletins.new.image'), class: 'form-label' %>
          <%= f.file_field :image, class: 'form-control', accept: 'image/*' %>
          <div class="form-text"><%= t('web.bulletins.new.image_hint') %></div>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit t('web.bulletins.new.submit'), class: 'btn btn-primary' %>
          <%= link_to t('web.bulletins.new.cancel'), root_path, class: 'btn btn-secondary' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
