<h1><%= t('admin.dashboard') %></h1>

<div class="row mt-4">
  <div class="col-md-6 mb-4">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title"><%= t('admin.categories.index.title') %></h5>
        <p class="card-text"><%= t('admin.categories.index.description') %></p>
        <%= link_to t('admin.categories.index.manage'), admin_categories_path, class: 'btn btn-primary' %>
      </div>
    </div>
  </div>

  <div class="col-md-6 mb-4">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title"><%= t('admin.bulletins.index.title') %></h5>
        <p class="card-text"><%= t('admin.bulletins.index.description') %></p>
        <%= link_to t('admin.bulletins.index.manage'), admin_bulletins_path, class: 'btn btn-primary' %>
      </div>
    </div>
  </div>
</div>
