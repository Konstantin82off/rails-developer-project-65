<div class="container mt-4">
  <h1><%= t('.title') %></h1>

  <%= form_with model: [:admin, @category], local: true do |form| %>
    <% if @category.errors.any? %>
      <div class="alert alert-danger">
        <h4><%= t('errors.messages.prohibited', count: @category.errors.count, model: t('activerecord.models.category')) %></h4>
        <ul>
          <% @category.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= form.label :name, t('.name'), class: 'form-label' %>
      <%= form.text_field :name, class: 'form-control', required: true %>
    </div>

    <div class="mb-3">
      <%= form.submit t('.submit'), class: 'btn btn-primary' %>
      <%= link_to t('.cancel'), admin_categories_path, class: 'btn btn-secondary' %>
    </div>
  <% end %>
</div>
