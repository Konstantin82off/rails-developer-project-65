<div class="border rounded shadow p-4 mb-4 bg-white">
  <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h1 class="h3 mb-0"><%= t('admin.categories.index.title') %></h1>
  </div>

  <div class="mb-4">
    <%= link_to t('admin.categories.index.new_category'), new_admin_category_path, class: 'text-primary text-decoration-underline' %>
  </div>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead>
         <tr>
          <th><%= t('admin.categories.index.id') %></th>
          <th><%= t('admin.categories.index.name') %></th>
          <th><%= t('admin.categories.index.actions') %></th>
        </tr>
      </thead>
      <tbody>
        <% @categories.each do |category| %>
          <tr>
            <td><%= category.id %></td>
            <td><%= category.name %></td>
            <td>
              <%= link_to t('admin.categories.index.edit'), edit_admin_category_path(category), class: 'btn btn-sm btn-link text-primary p-0 me-3' %>
              <%= button_to t('admin.categories.index.delete'), admin_category_path(category),
                  method: :delete,
                  class: 'btn btn-sm btn-link text-danger p-0',
                  form_class: 'd-inline',
                  data: { confirm: t('admin.categories.index.confirm_delete') } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
