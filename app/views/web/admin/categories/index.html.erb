<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= t('admin.categories.index.title') %></h1>
    <%= link_to t('admin.categories.index.new_category'), new_admin_category_path, class: 'btn btn-primary' %>
  </div>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead>
        <tr>
          <th>ID</th>
          <th><%= t('admin.categories.index.name') %></th>
          <th><%= t('admin.categories.index.created_at') %></th>
          <th><%= t('admin.categories.index.actions') %></th>
        </tr>
      </thead>
      <tbody>
        <% @categories.each do |category| %>
          <tr>
            <td><%= category.id %></td>
            <td><%= category.name %></td>
            <td><%= l(category.created_at, format: :short) if category.created_at %></td>
            <td>
              <%= link_to t('admin.categories.index.edit'), edit_admin_category_path(category), class: 'btn btn-sm btn-outline-primary me-2' %>
              <%= button_to t('admin.categories.index.delete'), admin_category_path(category), 
                  method: :delete, 
                  class: 'btn btn-sm btn-outline-danger',
                  data: { confirm: t('admin.categories.index.confirm_delete') } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
