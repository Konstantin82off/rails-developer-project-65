<div class="border rounded shadow p-4 mb-4 bg-white">
  <h1 class="h3 mb-4 pb-2 border-bottom"><%= t('web.admin.sidebar.all_bulletins') %></h1>

  <div class="bg-light p-4 rounded mb-4">
    <%= search_form_for @q, url: admin_bulletins_path, class: 'row g-3 align-items-start' do |f| %>
      <div class="col-12 col-md-6">
        <%= f.search_field :title_or_description_cont,
            class: 'form-control',
            placeholder: '' %>
        <label class="form-label small mt-1"><%= t('.search_label') %></label>
      </div>
      <div class="col-12 col-md-4">
        <%= f.select :state_eq,
            options_for_select([
              [t('.state_draft'), 'draft'],
              [t('.state_under_moderation'), 'under_moderation'],
              [t('.state_published'), 'published'],
              [t('.state_rejected'), 'rejected'],
              [t('.state_archived'), 'archived']
            ]),
            { include_blank: t('.all_statuses') },
            class: 'form-select' %>
        <label class="form-label small mt-1"><%= t('.status_label') %></label>
      </div>
      <div class="col-12 col-md-2">
        <div class="d-flex gap-2">
          <%= f.submit t('.search'), class: 'btn btn-primary btn-sm' %>
          <%= link_to t('.reset'), admin_bulletins_path, class: 'btn btn-outline-secondary btn-sm' %>
        </div>
      </div>
    <% end %>
  </div>

  <% if @bulletins.any? %>
    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead>
            <th><%= t('.title_field') %></th>
            <th><%= t('.status_field') %></th>
            <th><%= t('.created_at_field') %></th>
            <th><%= t('.actions') %></th>
          </thead>
        <tbody>
          <% @bulletins.each do |bulletin| %>
            <tr>
              <td><%= link_to bulletin.title, bulletin_path(bulletin), class: 'text-primary' %></td>
              <td>
                <span class="badge bg-<%= bulletin_state_color(bulletin.state) %>">
                  <%= t(".state_#{bulletin.state}") %>
                </span>
              </td>
              <td><%= l(bulletin.created_at, format: :short) %></td>
              <td class="actions-cell">
                <div class="d-flex flex-nowrap gap-2">
                  <%= link_to t('.show'), bulletin_path(bulletin), class: 'btn btn-sm btn-link text-primary p-0' %>
                  <% if bulletin.may_archive? %>
                    <%= button_to t('.archive'), archive_admin_bulletin_path(bulletin), method: :patch, data: { confirm: t('.confirm_archive') }, class: 'btn btn-sm btn-link text-danger p-0' %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-4">
      <%= paginate @bulletins, theme: 'bootstrap4' %>
    </div>
  <% else %>
    <div class="alert alert-info">
      <%= t('.no_bulletins') %>
    </div>
  <% end %>
</div>
