<div class="border rounded shadow p-4 mb-4 bg-white">
  <h1 class="h3 mb-4 pb-2 border-bottom"><%= t('web.admin.sidebar.moderation') %></h1>

  <% if @bulletins.any? %>
    <div class="table-responsive">
      <table class="table table-striped table-hover">
        <thead>
            <th><%= t('.title_field') %></th>
            <th><%= t('.created_at_field') %></th>
            <th><%= t('.actions') %></th>
          </thead>
        <tbody>
          <% @bulletins.each do |bulletin| %>
            <tr>
              <td><%= link_to bulletin.title, bulletin_path(bulletin), class: 'text-primary' %></td>
              <td><%= l(bulletin.created_at, format: :short) %></td>
              <td class="actions-cell">
                <div class="d-flex flex-nowrap gap-2">
                  <%= button_to t('.publish'), publish_admin_bulletin_path(bulletin), method: :patch, data: { confirm: t('.confirm_publish') }, class: 'btn btn-sm btn-link text-primary p-0' %>
                  <%= button_to t('.reject'), reject_admin_bulletin_path(bulletin), method: :patch, data: { confirm: t('.confirm_reject') }, class: 'btn btn-sm btn-link text-primary p-0' %>
                  <%= button_to t('.archive'), archive_admin_bulletin_path(bulletin), method: :patch, data: { confirm: t('.confirm_archive') }, class: 'btn btn-sm btn-link text-danger p-0' %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-4">
      <%= paginate @bulletins, theme: 'bootstrap4' %>
    </div>
  <% else %>
    <div class="alert alert-info">
      <%= t('.no_bulletins') %>
    </div>
  <% end %>
</div>
