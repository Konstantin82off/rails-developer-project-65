<div class="container mt-4">
  <div class="border rounded shadow p-4 mb-4 bg-white">
    <h1 class="h3 mb-2 pb-2 border-bottom"><%= t('web.profiles.show.title') %></h1>

    <div class="mb-4">
      <%= link_to t('web.profiles.show.new_bulletin'), new_bulletin_path, class: 'text-primary text-decoration-underline' %>
    </div>

    <!-- Форма поиска с серым фоном -->
    <div class="bg-light p-4 rounded mb-4">
      <%= search_form_for @q, url: profile_path, class: 'row g-3 align-items-start' do |f| %>
        <div class="col-12 col-md-6">
          <%= f.search_field :title_or_description_cont,
              class: 'form-control',
              placeholder: '' %>
          <label class="form-label small mt-1"><%= t('web.profiles.show.search_placeholder') %></label>
        </div>
        <div class="col-12 col-md-4">
          <%= f.select :state_eq,
              Bulletin.aasm.states.map { |state| [state.human_name, state.name] },
              { include_blank: true },
              class: 'form-select' %>
          <label class="form-label small mt-1"><%= t('web.profiles.show.all_statuses') %></label>
        </div>
        <div class="col-12 col-md-2">
          <div class="d-flex gap-2">
            <%= f.submit t('web.profiles.show.search_button'), class: 'btn btn-primary btn-sm' %>
            <%= link_to t('web.profiles.show.reset'), profile_path, class: 'btn btn-outline-secondary btn-sm' %>
          </div>
        </div>
      <% end %>
    </div>

    <% if @bulletins.present? %>
      <div class="table-responsive">
        <table class="table table-striped table-hover">
          <thead>
              <th><%= t('web.profiles.show.table.title') %></th>
              <th><%= t('web.profiles.show.table.status') %></th>
              <th><%= t('web.profiles.show.table.date') %></th>
              <th><%= t('web.profiles.show.table.actions') %></th>
            </thead>
          <tbody>
            <% @bulletins.each do |bulletin| %>
                <td><%= link_to bulletin.title, bulletin_path(bulletin), class: 'text-primary' %>
                <td>
                  <span class="badge bg-<%= bulletin_state_color(bulletin.state) %>">
                    <%= t("web.profiles.show.statuses.#{bulletin.state}") %>
                  </span>
                <td><%= l(bulletin.created_at, format: :short) %>
                <td>
                  <%= link_to t('web.profiles.show.actions.show'), bulletin_path(bulletin), class: 'btn btn-sm btn-link text-primary p-0 me-3' %>
                  <%= link_to t('web.profiles.show.actions.edit'), edit_bulletin_path(bulletin), class: 'btn btn-sm btn-link text-primary p-0 me-3' %>

                  <% if bulletin.draft? %>
                    <%= button_to t('web.profiles.show.actions.to_moderate'), to_moderate_bulletin_path(bulletin),
                        method: :patch,
                        class: 'btn btn-sm btn-link text-primary p-0 me-3',
                        form_class: 'd-inline' %>
                  <% end %>

                  <% if bulletin.may_archive? %>
                    <%= button_to t('web.profiles.show.actions.archive'), archive_bulletin_path(bulletin),
                        method: :patch,
                        class: 'btn btn-sm btn-link text-danger p-0 me-3',
                        form_class: 'd-inline',
                        data: { confirm: t('common.confirm') } %>
                  <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="mt-4">
        <%= paginate @bulletins, theme: 'bootstrap4' %>
      </div>
    <% else %>
      <div class="alert alert-info">
        <%= t('web.profiles.show.no_bulletins') %> <%= link_to t('web.profiles.show.create_first'), new_bulletin_path %>
      </div>
    <% end %>
  </div>
</div>
