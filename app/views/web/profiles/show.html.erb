<div class="container mt-4">
  <div class="row">
    <div class="col-md-3">
      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title"><%= current_user.name %></h5>
          <p class="card-text"><%= current_user.email %></p>
        </div>
      </div>

      <h4>Поиск по моим объявлениям</h4>
      <%= search_form_for @q, url: profile_path, class: 'mb-4' do |f| %>
        <div class="mb-3">
          <%= f.label :title_or_description_cont, 'Название или описание', class: 'form-label' %>
          <%= f.search_field :title_or_description_cont, class: 'form-control', placeholder: 'Введите текст...' %>
        </div>
        
        <div class="mb-3">
          <%= f.label :category_id_eq, 'Категория', class: 'form-label' %>
          <%= f.collection_select :category_id_eq, Category.all, :id, :name, 
              { include_blank: 'Любая' }, class: 'form-select' %>
        </div>
        
        <div class="mb-3">
          <%= f.label :state_eq, 'Статус', class: 'form-label' %>
          <%= f.select :state_eq, 
              options_for_select([
                ['Черновик', 'draft'],
                ['На модерации', 'under_moderation'],
                ['Опубликовано', 'published'],
                ['Отклонено', 'rejected'],
                ['В архиве', 'archived']
              ]),
              { include_blank: 'Любой' }, class: 'form-select' %>
        </div>
        
        <%= f.submit 'Искать', class: 'btn btn-primary w-100' %>
        <%= link_to 'Сбросить', profile_path, class: 'btn btn-outline-secondary w-100 mt-2' %>
      <% end %>
    </div>

    <div class="col-md-9">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Мои объявления</h1>
        <%= link_to 'Создать объявление', new_bulletin_path, class: 'btn btn-primary' %>
      </div>

      <% if @bulletins.present? %>
        <div class="table-responsive">
          <table class="table table-striped table-hover">
            <thead>
              发展
                <th>Заголовок</th>
                <th>Категория</th>
                <th>Статус</th>
                <th>Дата</th>
                <th>Действия</th>
              </tr>
            </thead>
            <tbody>
              <% @bulletins.each do |bulletin| %>
                <tr>
                  <td><%= link_to bulletin.title, bulletin_path(bulletin) %></td>
                  <td><%= bulletin.category.name %></td>
                  <td>
                    <span class="badge bg-<%= bulletin_state_color(bulletin.state) %>">
                      <%= t("web.profiles.show.statuses.#{bulletin.state}") %>
                    </span>
                  </td>
                  <td><%= l(bulletin.created_at, format: :short) %></td>
                  <td>
                    <% if bulletin.may_to_moderate? %>
                      <%= button_to 'На модерацию', to_moderate_bulletin_path(bulletin), 
                          method: :patch, 
                          class: 'btn btn-sm btn-warning me-2',
                          form_class: 'd-inline' %>
                    <% end %>
                    
                    <% if bulletin.may_archive? %>
                      <%= button_to 'В архив', archive_bulletin_path(bulletin), 
                          method: :patch, 
                          class: 'btn btn-sm btn-secondary me-2',
                          form_class: 'd-inline',
                          data: { confirm: 'Вы уверены?' } %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="mt-4">
          <%= paginate @bulletins, theme: 'bootstrap-5' %>
        </div>
      <% else %>
        <div class="alert alert-info">
          У вас пока нет объявлений. <%= link_to 'Создать первое объявление', new_bulletin_path %>
        </div>
      <% end %>
    </div>
  </div>
</div>
