<div class="container mt-4">
  <div class="row">
    <div class="col-md-3">
      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title"><%= current_user.name %></h5>
          <p class="card-text"><%= current_user.email %></p>
        </div>
      </div>

      <h4><%= t('web.profiles.show.search') %></h4>
      <%= search_form_for @q, url: profile_path, class: 'mb-4' do |f| %>
        <div class="mb-3">
          <%= f.label :title_or_description_cont, t('web.profiles.show.title_or_description'), class: 'form-label' %>
          <%= f.search_field :title_or_description_cont, class: 'form-control', placeholder: t('web.profiles.show.search_placeholder') %>
        </div>

        <div class="mb-3">
          <%= f.label :category_id_eq, t('web.profiles.show.category'), class: 'form-label' %>
          <%= f.collection_select :category_id_eq, Category.all, :id, :name,
              { include_blank: t('web.profiles.show.all_categories') }, class: 'form-select' %>
        </div>

        <div class="mb-3">
          <%= f.label :state_eq, t('web.profiles.show.status'), class: 'form-label' %>
          <%= f.select :state_eq,
              options_for_select([
                [t('web.profiles.show.statuses.draft'), 'draft'],
                [t('web.profiles.show.statuses.under_moderation'), 'under_moderation'],
                [t('web.profiles.show.statuses.published'), 'published'],
                [t('web.profiles.show.statuses.rejected'), 'rejected'],
                [t('web.profiles.show.statuses.archived'), 'archived']
              ]),
              { include_blank: t('web.profiles.show.all_statuses') }, class: 'form-select' %>
        </div>

        <%= f.submit t('web.profiles.show.search_button'), class: 'btn btn-primary w-100' %>
        <%= link_to t('web.profiles.show.reset'), profile_path, class: 'btn btn-outline-secondary w-100 mt-2' %>
      <% end %>
    </div>

    <div class="col-md-9">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><%= t('web.profiles.show.title') %></h1>
        <%= link_to t('web.profiles.show.new_bulletin'), new_bulletin_path, class: 'btn btn-primary' %>
      </div>

      <% if @bulletins.present? %>
        <div class="table-responsive">
          <table class="table table-striped table-hover">
            <thead>
                <th><%= t('web.profiles.show.table.title') %></th>
                <th><%= t('web.profiles.show.table.category') %></th>
                <th><%= t('web.profiles.show.table.status') %></th>
                <th><%= t('web.profiles.show.table.date') %></th>
                <th><%= t('web.profiles.show.table.actions') %></th>
              </tr>
            </thead>
            <tbody>
              <% @bulletins.each do |bulletin| %>
                <tr>
                  <td><%= link_to bulletin.title, bulletin_path(bulletin) %></td>
                  <td><%= bulletin.category.name %></td>
                  <td>
                    <span class="badge bg-<%= bulletin_state_color(bulletin.state) %>">
                      <%= t("web.profiles.show.statuses.#{bulletin.state}") %>
                    </span>
                  </td>
                  <td><%= l(bulletin.created_at, format: :short) %></td>
                  <td>
                    <% if bulletin.may_to_moderate? %>
                      <%= button_to t('web.profiles.show.actions.to_moderate'), to_moderate_bulletin_path(bulletin),
                          method: :patch,
                          class: 'btn btn-sm btn-warning me-2',
                          form_class: 'd-inline' %>
                    <% end %>

                    <% if bulletin.may_archive? %>
                      <%= button_to t('web.profiles.show.actions.archive'), archive_bulletin_path(bulletin),
                          method: :patch,
                          class: 'btn btn-sm btn-secondary me-2',
                          form_class: 'd-inline',
                          data: { confirm: t('common.confirm') } %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <div class="mt-4">
          <%= paginate @bulletins, theme: 'bootstrap-5' %>
        </div>
      <% else %>
        <div class="alert alert-info">
          <%= t('web.profiles.show.no_bulletins') %> <%= link_to t('web.profiles.show.create_first'), new_bulletin_path %>
        </div>
      <% end %>
    </div>
  </div>
</div>
