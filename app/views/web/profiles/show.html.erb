<div class="container mt-4">
  <h1 class="mb-4">Мои объявления</h1>

  <div class="row">
    <div class="col-md-3">
      <div class="card mb-4">
        <div class="card-body">
          <h5 class="card-title"><%= current_user.name %></h5>
          <p class="card-text"><%= current_user.email %></p>
        </div>
      </div>
    </div>

    <div class="col-md-9">
      <% if @bulletins.any? %>
        <div class="table-responsive">
          <table class="table table-striped table-hover">
            <thead>
              <tr>
                <th>Заголовок</th>
                <th>Категория</th>
                <th>Статус</th>
                <th>Дата</th>
                <th>Действия</th>
              </tr>
            </thead>
            <tbody>
              <% @bulletins.each do |bulletin| %>
                <tr>
                  <td><%= link_to bulletin.title, bulletin_path(bulletin) %></td>
                  <td><%= bulletin.category.name %></td>
                  <td>
                    <span class="badge bg-<%= bulletin_state_color(bulletin.state) %>">
                      <%= bulletin.human_state_name %>
                    </span>
                  </td>
                  <td><%= l(bulletin.created_at, format: :short) %></td>
                  <td>
                    <% if bulletin.may_to_moderate? %>
                      <%= button_to 'На модерацию', to_moderate_bulletin_path(bulletin), 
                          method: :patch, 
                          class: 'btn btn-sm btn-warning me-2',
                          form_class: 'd-inline' %>
                    <% end %>
                    
                    <% if bulletin.may_archive? %>
                      <%= button_to 'В архив', archive_bulletin_path(bulletin), 
                          method: :patch, 
                          class: 'btn btn-sm btn-secondary me-2',
                          form_class: 'd-inline',
                          data: { confirm: 'Вы уверены?' } %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="alert alert-info">
          У вас пока нет объявлений. <%= link_to 'Создать первое объявление', new_bulletin_path %>
        </div>
      <% end %>
    </div>
  </div>
</div>
