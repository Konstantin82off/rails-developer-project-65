<div class="row">
  <div class="col-md-3">
    <h4>Категории</h4>
    <div class="list-group">
      <%= link_to 'Все объявления', root_path, class: "list-group-item list-group-item-action #{'active' unless params[:category_id]}" %>
      <% @categories.each do |category| %>
        <%= link_to category.name, root_path(category_id: category.id), 
            class: "list-group-item list-group-item-action #{'active' if params[:category_id].to_i == category.id}" %>
      <% end %>
    </div>
  </div>
  
  <div class="col-md-9">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1>Последние объявления</h1>
      <% if user_signed_in? %>
        <%= link_to 'Подать объявление', new_bulletin_path, class: 'btn btn-primary' %>
      <% end %>
    </div>

    <div class="row">
      <% @bulletins.each do |bulletin| %>
        <div class="col-md-6 mb-4">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title"><%= link_to bulletin.title, bulletin_path(bulletin) %></h5>
              <p class="card-text"><%= truncate(bulletin.description, length: 100) %></p>
              <p class="card-text">
                <small class="text-muted">
                  Категория: <%= bulletin.category.name %><br>
                  Автор: <%= bulletin.user.name %><br>
                  <%= time_ago_in_words(bulletin.created_at) %> назад
                </small>
              </p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
