<!DOCTYPE html>
<html>
  <head>
    <title><%= t('layouts.application.title') %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
      <div class="container px-5">
        <div class="d-flex align-items-center gap-3">
          <%= link_to t('layouts.application.brand'), root_path, class: "navbar-brand fs-5 fw-normal" %>
          <%= link_to t('web.bulletins.index.home'), root_path, class: "nav-link fs-6 text-secondary" %>
        </div>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <% if signed_in? %>
              <li class="nav-item">
                <%= link_to t('web.profiles.show.title'), profile_path, class: "nav-link fs-6" %>
              </li>
              <li class="nav-item">
                <%= link_to t('auth.logout'), logout_path, class: "nav-link fs-6", data: { turbo_method: :delete } %>
              </li>
            <% else %>
              <li class="nav-item">
                <a href="/auth/github" class="nav-link fs-6">
                  <i class="bi bi-github me-1"></i> <%= t('auth.login') %>
                </a>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <main class="container px-5 mt-4">
      <% if notice %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
