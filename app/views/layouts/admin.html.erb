<!DOCTYPE html>
<html>
  <head>
    <title><%= t('layouts.application.title') %> - <%= t('admin.dashboard') %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
      <div class="container-fluid" style="padding-left: 8rem; padding-right: 8rem;">
        <div class="d-flex align-items-center gap-3">
          <%= link_to t('layouts.application.brand'), root_path, class: "navbar-brand fs-5 fw-normal" %>
          <%= link_to t('web.bulletins.index.home'), root_path, class: "nav-link fs-6 text-secondary" %>
          <% if signed_in? %>
            <%= link_to t('web.profiles.show.title'), profile_path, class: "nav-link fs-6 text-secondary" %>
            <%= link_to t('web.bulletins.index.new_bulletin'), new_bulletin_path, class: "nav-link fs-6 text-secondary" %>
          <% end %>
        </div>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <% if signed_in? %>
              <% if current_user.admin? %>
                <li class="nav-item">
                  <%= link_to t('admin.dashboard'), admin_root_path, class: "nav-link fs-6" %>
                </li>
              <% end %>
              <li class="nav-item">
                <%= link_to t('auth.logout'), logout_path, class: "nav-link fs-6", data: { turbo_method: :delete } %>
              </li>
            <% else %>
              <li class="nav-item">
                <a href="/auth/github" class="nav-link fs-6">
                  <i class="bi bi-github me-1"></i> <%= t('auth.login') %>
                </a>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container-fluid" style="padding-left: 8rem; padding-right: 8rem;">
      <div class="row mt-4">
        <!-- Левая боковая панель -->
        <div class="col-md-3">
          <div class="list-group">
            <%= link_to t('admin.sidebar.moderation'), admin_root_path, class: "list-group-item list-group-item-action #{current_page?(admin_root_path) ? 'active' : ''}" %>
            <%= link_to t('admin.sidebar.all_bulletins'), admin_bulletins_path, class: "list-group-item list-group-item-action #{current_page?(admin_bulletins_path) ? 'active' : ''}" %>
            <%= link_to t('admin.sidebar.categories'), admin_categories_path, class: "list-group-item list-group-item-action #{current_page?(admin_categories_path) ? 'active' : ''}" %>
          </div>
        </div>

        <!-- Основное содержимое -->
        <div class="col-md-9">
          <% if notice %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
              <%= notice %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% end %>
          <% if alert %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <%= alert %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </div>
    </div>
  </body>
</html>
