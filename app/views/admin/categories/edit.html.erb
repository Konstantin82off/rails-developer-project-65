<div class="container mt-4">
  <h1><%= t('admin.categories.edit.title') %></h1>

  <%= form_with model: [:admin, @category], local: true do |form| %>
    <% if @category.errors.any? %>
      <div class="alert alert-danger">
        <h4><%= pluralize(@category.errors.count, "ошибка") %>:</h4>
        <ul>
          <% @category.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= form.label :name, t('admin.categories.edit.name'), class: 'form-label' %>
      <%= form.text_field :name, class: 'form-control', required: true %>
    </div>

    <div class="mb-3">
      <%= form.submit t('admin.categories.edit.submit'), class: 'btn btn-primary' %>
      <%= link_to t('admin.categories.edit.cancel'), admin_categories_path, class: 'btn btn-secondary' %>
    </div>
  <% end %>
</div>
