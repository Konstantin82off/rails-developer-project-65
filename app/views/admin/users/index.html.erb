<div class="container mt-4">
  <h1 class="mb-4"><%= t('admin.users.index.title') %></h1>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead>
        <tr>
          <th>ID</th>
          <th><%= t('admin.users.index.name') %></th>
          <th><%= t('admin.users.index.email') %></th>
          <th><%= t('admin.users.index.admin') %></th>
          <th><%= t('admin.users.index.created_at') %></th>
          <th><%= t('admin.users.index.actions') %></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.id %></td>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td>
              <% if user.admin? %>
                <span class="badge bg-success"><%= t('admin.users.index.yes') %></span>
              <% else %>
                <span class="badge bg-secondary"><%= t('admin.users.index.no') %></span>
              <% end %>
            </td>
            <td><%= l(user.created_at, format: :short) if user.created_at %></td>
            <td>
              <%= link_to t('admin.users.index.edit'), edit_admin_user_path(user), class: 'btn btn-sm btn-outline-primary' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
