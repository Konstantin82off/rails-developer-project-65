<div class="container mt-4">
  <h1><%= t('admin.users.edit.title') %></h1>

  <%= form_with model: [:admin, @user], local: true do |form| %>
    <% if @user.errors.any? %>
      <div class="alert alert-danger">
        <h4><%= pluralize(@user.errors.count, "ошибка") %>:</h4>
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= form.label :name, t('admin.users.edit.name'), class: 'form-label' %>
      <%= form.text_field :name, class: 'form-control' %>
    </div>

    <div class="mb-3">
      <%= form.label :email, t('admin.users.edit.email'), class: 'form-label' %>
      <%= form.email_field :email, class: 'form-control' %>
    </div>

    <div class="mb-3 form-check">
      <%= form.check_box :admin, class: 'form-check-input' %>
      <%= form.label :admin, t('admin.users.edit.admin_status'), class: 'form-check-label' %>
    </div>

    <div class="mb-3">
      <%= form.submit t('admin.users.edit.save'), class: 'btn btn-primary' %>
      <%= link_to t('admin.users.edit.cancel'), admin_users_path, class: 'btn btn-secondary' %>
    </div>
  <% end %>
</div>
