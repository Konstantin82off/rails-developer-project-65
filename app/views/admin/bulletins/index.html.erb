<div class="container mt-4">
  <h1 class="mb-4"><%= t('admin.bulletins.index.title') %></h1>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead>
        <tr>
          <th>ID</th>
          <th><%= t('admin.bulletins.index.title_field') %></th>
          <th><%= t('admin.bulletins.index.user') %></th>
          <th><%= t('admin.bulletins.index.category') %></th>
          <th><%= t('admin.bulletins.index.created_at') %></th>
          <th><%= t('admin.bulletins.index.actions') %></th>
        </tr>
      </thead>
      <tbody>
        <% @bulletins.each do |bulletin| %>
          <tr>
            <td><%= bulletin.id %></td>
            <td><%= truncate(bulletin.title, length: 50) %></td>
            <td><%= bulletin.user.name %></td>
            <td><%= bulletin.category.name %></td>
            <td><%= l(bulletin.created_at, format: :short) %></td>
            <td>
              <%= link_to t('admin.bulletins.index.view'), admin_bulletin_path(bulletin), class: 'btn btn-sm btn-outline-info me-2' %>
              <%= link_to t('admin.bulletins.index.edit'), edit_admin_bulletin_path(bulletin), class: 'btn btn-sm btn-outline-primary me-2' %>
              <%= button_to t('admin.bulletins.index.delete'), admin_bulletin_path(bulletin), 
                  method: :delete, 
                  class: 'btn btn-sm btn-outline-danger',
                  data: { confirm: t('admin.bulletins.index.confirm_delete') } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
