<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= t('admin.bulletins.index.title') %></h1>
  </div>

  <div class="row">
    <div class="col-md-3">
      <h4>Поиск</h4>
      <%= search_form_for @q, url: admin_bulletins_path, class: 'mb-4' do |f| %>
        <div class="mb-3">
          <%= f.label :title_or_description_cont, 'Название или описание', class: 'form-label' %>
          <%= f.search_field :title_or_description_cont, class: 'form-control', placeholder: 'Введите текст...' %>
        </div>
        
        <div class="mb-3">
          <%= f.label :user_name_cont, 'Пользователь', class: 'form-label' %>
          <%= f.search_field :user_name_cont, class: 'form-control', placeholder: 'Имя пользователя...' %>
        </div>
        
        <div class="mb-3">
          <%= f.label :category_id_eq, 'Категория', class: 'form-label' %>
          <%= f.collection_select :category_id_eq, Category.all, :id, :name, 
              { include_blank: 'Любая' }, class: 'form-select' %>
        </div>
        
        <div class="mb-3">
          <%= f.label :state_eq, 'Статус', class: 'form-label' %>
          <%= f.select :state_eq, 
              options_for_select([
                ['Черновик', 'draft'],
                ['На модерации', 'under_moderation'],
                ['Опубликовано', 'published'],
                ['Отклонено', 'rejected'],
                ['В архиве', 'archived']
              ]),
              { include_blank: 'Любой' }, class: 'form-select' %>
        </div>
        
        <%= f.submit 'Искать', class: 'btn btn-primary w-100' %>
        <%= link_to 'Сбросить', admin_bulletins_path, class: 'btn btn-outline-secondary w-100 mt-2' %>
      <% end %>
    </div>

    <div class="col-md-9">
      <div class="table-responsive">
        <table class="table table-striped table-hover">
          <thead>
            <tr>
              <th>ID</th>
              <th>Заголовок</th>
              <th>Пользователь</th>
              <th>Категория</th>
              <th>Статус</th>
              <th>Дата</th>
              <th>Действия</th>
            </tr>
          </thead>
          <tbody>
            <% @bulletins.each do |bulletin| %>
              <tr>
                <td><%= bulletin.id %></td>
                <td><%= truncate(bulletin.title, length: 50) %></td>
                <td><%= bulletin.user.name %></td>
                <td><%= bulletin.category.name %></td>
                <td>
                  <span class="badge bg-<%= bulletin_state_color(bulletin.state) %>">
                    <%= t("web.profiles.show.statuses.#{bulletin.state}") %>
                  </span>
                </td>
                <td><%= l(bulletin.created_at, format: :short) %></td>
                <td>
                  <%= link_to t('admin.bulletins.index.view'), admin_bulletin_path(bulletin), class: 'btn btn-sm btn-outline-info me-2' %>
                  <%= link_to t('admin.bulletins.index.edit'), edit_admin_bulletin_path(bulletin), class: 'btn btn-sm btn-outline-primary' %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="mt-4">
        <%= paginate @bulletins, theme: 'bootstrap-5' %>
      </div>
    </div>
  </div>
</div>
