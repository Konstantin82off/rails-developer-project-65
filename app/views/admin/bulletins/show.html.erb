<div class="container mt-4">
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h2 class="mb-0"><%= @bulletin.title %></h2>
      <span class="badge bg-primary"><%= @bulletin.category.name %></span>
    </div>
    
    <div class="card-body">
      <% if @bulletin.image.attached? %>
        <div class="text-center mb-4">
          <%= image_tag @bulletin.image.variant(resize_to_limit: [400, 300]), class: "img-fluid rounded" %>
        </div>
      <% end %>
      
      <div class="mb-4">
        <h5><%= t('admin.bulletins.show.description') %>:</h5>
        <p class="lead"><%= @bulletin.description %></p>
      </div>
      
      <div class="row mb-3">
        <div class="col-sm-6">
          <strong><%= t('admin.bulletins.show.author') %>:</strong> <%= @bulletin.user.name %>
        </div>
        <div class="col-sm-6">
          <strong><%= t('admin.bulletins.show.created_at') %>:</strong> <%= l(@bulletin.created_at, format: :long) %>
        </div>
      </div>
      
      <%# Кнопки для управления состояниями %>
      <div class="mt-4">
        <h5>Управление состоянием:</h5>
        <div class="d-flex gap-2">
          <% if @bulletin.may_publish? %>
            <%= button_to 'Опубликовать', publish_admin_bulletin_path(@bulletin), 
                method: :patch, 
                class: 'btn btn-success',
                form_class: 'd-inline' %>
          <% end %>

          <% if @bulletin.may_reject? %>
            <%= button_to 'Отклонить', reject_admin_bulletin_path(@bulletin), 
                method: :patch, 
                class: 'btn btn-warning',
                form_class: 'd-inline' %>
          <% end %>

          <% if @bulletin.may_archive? %>
            <%= button_to 'В архив', archive_admin_bulletin_path(@bulletin), 
                method: :patch, 
                class: 'btn btn-secondary',
                form_class: 'd-inline',
                data: { confirm: 'Вы уверены?' } %>
          <% end %>
        </div>
      </div>
    </div>
    
    <div class="card-footer">
      <div class="d-flex justify-content-between">
        <%= link_to t('admin.bulletins.show.back'), admin_bulletins_path, class: 'btn btn-outline-secondary' %>
        <div>
          <%= link_to t('admin.bulletins.show.edit'), edit_admin_bulletin_path(@bulletin), class: 'btn btn-outline-primary me-2' %>
          <%= button_to t('admin.bulletins.show.delete'), admin_bulletin_path(@bulletin), 
              method: :delete, 
              class: 'btn btn-outline-danger',
              data: { confirm: t('admin.bulletins.show.confirm_delete') } %>
        </div>
      </div>
    </div>
  </div>
</div>
